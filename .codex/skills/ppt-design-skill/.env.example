# PPT Design Skill — API Keys Configuration
# Copy this file to .env and fill in your keys

# === Image Generation Engines ===

# Seedream (Volcengine/ByteDance) — default engine
ARK_API_KEY=
ARK_BASE_URL=
ARK_IMAGE_MODEL=

# GPT Image / DALL-E (OpenAI)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=

# Gemini Image (Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_IMAGE_MODEL=

# Wanx / Tongyi (Alibaba Cloud)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
DASHSCOPE_IMAGE_MODEL=

# Kimi (Moonshot) — enhance mode
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=
MOONSHOT_IMAGE_MODEL=

# === Image Search Engines ===

# Unsplash
UNSPLASH_ACCESS_KEY=

# Pexels
PEXELS_API_KEY=
